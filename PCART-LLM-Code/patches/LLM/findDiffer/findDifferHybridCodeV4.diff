+def buildPromptMessages(apiCall, oldVersion, newVersion, oldParamsJSON, newParamsJSON,
+                        oldSourceCode, newSourceCode):
+    user_prompt = HUMAN_PROMPT_TEMPLATE.format(
+        fullApiName=apiCall,
+        oldVersion=oldVersion,
+        newVersion=newVersion,
+        oldParamsJSON=oldParamsJSON,
+        newParamsJSON=newParamsJSON,
+        oldSourceCode=oldSourceCode,
+        newSourceCode=newSourceCode,
+    )
+    return [
+        {"role": "system", "content": SYSTEM_PROMPT_TEMPLATE},
+        {"role": "user", "content": user_prompt},
+    ]
