+SYSTEM_PROMPT_TEMPLATE = """You are an API parameter change analysis assistant. Your task is to analyze parameter changes between different API versions and output the results in a specific JSON format.
+
+<task>
+Determine which parameters from the old version have been renamed in the new version.
+</task>
+
+<rules>
+RENAME: A parameter must satisfy **all** of the following conditions:
+a) The parameter is semantically the same parameter with a name change, or the new parameter extends the functionality of the old one with full backward compatibility (reference docstrings, source code, and data types).
+b) For keyword parameters: position does **not** matter.
+c) For positional parameters: position **must** remain the same.
+</rules>
+"""
+
+HUMAN_PROMPT_TEMPLATE = """<general_information>
+
+### API call
+{fullApiName}
+
+### Library and version
+- old：{oldVersion}
+- new：{newVersion}
+
+</general_information>
