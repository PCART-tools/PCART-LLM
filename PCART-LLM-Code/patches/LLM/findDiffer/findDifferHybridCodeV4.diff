+## Call LLM to analyze parameter changes using OpenAI official SDK
+## 调用 LLM 分析参数变更（使用 OpenAI 官方 SDK 和 JSON Schema）
+#
+#  @param apiCall The full API name without parameters
+#  @param oldVersion The old library version
+#  @param newVersion The new library version
+#  @param oldPosRemaining Remaining old positional parameters
+#  @param oldKeyRemaining Remaining old keyword parameters
+#  @param newPosRemaining Remaining new positional parameters
+#  @param newKeyRemaining Remaining new keyword parameters
+#  @param oldDocstring The old version docstring
+#  @param newDocstring The new version docstring
+#  @param oldSourceCode The old version source code (optional)
+#  @param newSourceCode The new version source code (optional)
+#  @param maxRetries Maximum number of retry attempts (default: 3)
+#  @return resultDict containing parameter modifications from LLM output
+def callLLM(apiCall, oldVersion, newVersion, oldPosRemaining, oldKeyRemaining,
+            newPosRemaining, newKeyRemaining,
+            oldSourceCode='', newSourceCode='', maxRetries=3):
+    # 调用 LLM 分析参数变更，使用 OpenAI 官方 SDK。
+
+    if shouldSkipLLM(apiCall):
+        print(f"[LLM-Hybrid] Skip LLM invocation for API: {apiCall}")
+        return {"changes": []}
+
+    # 从环境变量获取配置
+
+    client = OpenAI(
+        # api_key=apiKey,
+        # base_url=baseUrl,
+    )
+
+    # 转换为 JSON 格式字符串供提示词使用
+    oldParamsJSON = convertParamsToJSON(oldPosRemaining, True) + convertParamsToJSON(oldKeyRemaining, False)
+    newParamsJSON = convertParamsToJSON(newPosRemaining, True) + convertParamsToJSON(newKeyRemaining, False)
+
+    old_params_str = json.dumps(oldParamsJSON, indent=2, ensure_ascii=False)
+    new_params_str = json.dumps(newParamsJSON, indent=2, ensure_ascii=False)
+
+    messages = buildPromptMessages(
+        apiCall,
+        oldVersion,
+        newVersion,
+        old_params_str,
+        new_params_str,
+        oldSourceCode,
+        newSourceCode,
+    )
+
+    print(
+        "--- Prompt Sent to LLM ---\n"
+        f"[system]\n{SYSTEM_PROMPT_TEMPLATE}\n\n"
+        f"[user]\n{messages[1]['content']}\n"
+        "---------------------------\n\n"
+    )
+
+    if _llm_debug_enabled():
+        print(
+            "\n[FIND_DIFFER_LLM_DEBUG] 已开启：将打印每次 API 返回的完整结构化对象。"
+            "关闭: unset FIND_DIFFER_LLM_DEBUG\n"
+        )
+
+    for attempt in range(1, maxRetries + 1):
+        try:
+            response = client.chat.completions.create(
+                model="claude-opus-4-6-thinking",
+                messages=messages,
+                temperature=0,
+                max_tokens=8192,
+                response_format={
+                    "type": "json_schema",
+                    "json_schema": {
+                        "name": "ParameterChanges",
+                        "schema": parameter_changes_schema,
+                    },
+                },
+            )
+            print_llm_raw_response(response, f"chat.completions 原始返回 (attempt {attempt})")
+            result = parseStructuredResponse(response)
+            print(result)
+            print(f"[LLM] Response received. Changes: {result}")
+            return result
+        except Exception as e:
+            if _llm_debug_enabled():
+                print(f"\n[FIND_DIFFER_LLM_DEBUG] 本次异常: {type(e).__name__}: {e}")
+                traceback.print_exc()
+            if attempt == maxRetries:
+                print(f"Error during LLM invocation: {e}")
+                return {"changes": []}
+            print(f"[LLM] Attempt {attempt} failed: {e}. Retrying...")
+
+
+## Apply LLM analysis results to the existing dictionary
+## 将 LLM 返回的分析结果应用到现有字典中
+#
+#  @param dic The existing dictionary from hard rules preprocessing
+#  @param llmResult The LLM analysis result
+#  @param oldPosRemaining Remaining old positional parameters
+#  @param oldKeyRemaining Remaining old keyword parameters
+#  @param newPosRemaining Remaining new positional parameters
+#  @param newKeyRemaining Remaining new keyword parameters
+#  @return dic The merged dictionary
+def applyLLMResult(dic, llmResult, oldPosRemaining, oldKeyRemaining,
+                   newPosRemaining, newKeyRemaining):
+    # 应用 LLM 返回的分析结果。
+    # 处理 LLM 返回的重命名操作，并将剩余的旧参数标记为删除。
+    changes = llmResult.get('changes', [])
+
+    # 创建旧参数映射：从 (name, position) 到参数对象
+    oldParamMap = {}
+    for para in oldPosRemaining + oldKeyRemaining:
+        oldParamMap[(para.name, para.position)] = para
+
+    # 创建新参数映射：从 name 到参数对象（用于重命名查找）
+    newParamMap = {}
+    for para in newPosRemaining + newKeyRemaining:
+        if para.name not in newParamMap:
+            newParamMap[para.name] = para
+
+    # 处理 LLM 返回的重命名
+    for change in changes:
+        paramName = change.get('param_name')
+        position = change.get('position')
+        key = (paramName, position)
+
+        if key in oldParamMap and 'rename' in change:
+            oldPara = oldParamMap[key]
+            newName = change['rename']
+
+            if newName in newParamMap:
+                newPara = newParamMap[newName]
+                up = Update()
+                up.rename = newName
+                ty = isDifferType(oldPara.type, newPara.type)
+                if ty:
+                    up.type = ty
+                dic[key] = up
+
+                # 从剩余参数中移除
+                if oldPara in oldPosRemaining:
+                    oldPosRemaining.remove(oldPara)
+                elif oldPara in oldKeyRemaining:
+                    oldKeyRemaining.remove(oldPara)
+                if newPara in newPosRemaining:
+                    newPosRemaining.remove(newPara)
+                elif newPara in newKeyRemaining:
+                    newKeyRemaining.remove(newPara)
+
+    # 将剩余的旧参数标记为删除
+    for oldPara in oldPosRemaining:
+        up = Update()
+        up.dele = 1
+        dic[(oldPara.name, oldPara.position)] = up
+
+    for oldPara in oldKeyRemaining:
+        up = Update()
+        up.dele = 1
+        dic[(oldPara.name, oldPara.position)] = up
+
+    return dic
+
+
+## Apply hard rules postprocessing for new parameters
+## 应用硬规则后处理，处理新增和替换参数
+#
+#  这部分对应 changeAnalyze.py:434-457 的后置硬规则处理
+#
+#  @param dic The dictionary of parameter changes
+#  @param newPosRemaining Remaining new positional parameters
+#  @param newKeyRemaining Remaining new keyword parameters
+#  @param oldPosParaNum The number of old positional parameters
+#  @return dic The updated dictionary
+def applyPostprocessing(dic, newPosRemaining, newKeyRemaining, oldPosParaNum):
+    # newPos中剩下的就是替换或新增的
+    for para in newPosRemaining:
+        s = f'{para.name}'
+        if para.value:
+            s += f"={para.value}"
+        if para.position >= 0 and para.position < oldPosParaNum:  # 如果剩余参数的下标在旧版本参数下标的范围内，则认为是替换操作,反之则认为是新增的
+            for key in dic:
+                if key[1] == para.position:
+                    dic[key].rep = s
+                    break
+        else:
+            up = Update()
+            up.addPos = s
+            dic[(para.name, para.position)] = up
+
+    # newKey中剩下的就是新增的,新增的关键字参数往往都带有默认值，一般不会引起兼容性问题
+    for para in newKeyRemaining:
+        s = para.name
+        if para.value:
+            s += f"={para.value}"
+        up = Update()
+        up.addKey = s
+        dic[(para.name, para.position)] = up
+
+    return dic
+
+
+
+## Build final answer dictionary
+## 构建最终的答案字典
+#
+#  @param dic The dictionary of parameter changes
+#  @return ansDict The final answer dictionary sorted by position
+def buildFinalAnswerDict(dic):
+    # 构建修改操作的字典
+    updateDict = {}
+    for key, value in dic.items():
+        if key not in updateDict:
+            updateDict[key] = {}
+        if value.dele:
+            updateDict[key]['delete'] = value.dele
+        if value.type:
+            updateDict[key]['typeChange'] = value.type
+        if value.rename:
+            updateDict[key]['rename'] = value.rename
+        if value.pos != -1:
+            updateDict[key]['posChange'] = value.pos
+        if value.rep:
+            updateDict[key]['replace'] = value.rep
+        if value.pos2key:
+            updateDict[key]['pos2key'] = value.pos2key
+        if value.addPos:
+            updateDict[key]['addPos'] = value.addPos
+        if value.addKey:
+            updateDict[key]['addKey'] = value.addKey
+        if value.key2pos:
+            updateDict[key]['key2pos'] = value.key2pos
+
+    # 对字典按照参数的位置进行排序
+    ansDict = dict(sorted(updateDict.items(), key=lambda it: it[0][1]))  # it[0]代表字典的键，it[0][1]代表键中的第二个元素,即位置
+    return ansDict
+
+
+## Hybrid difference analysis using LLM
+## 使用 LLM 进行混合差异分析
+#
+#  @param oldPara The old parameter string from current version
+#  @param newPara The new parameter string from target version
+#  @param context A dictionary containing all additional context for LLM analysis:
+#         - apiCall: The API call name
+#         - oldVersion: The old library version (e.g., "networkx@1.5")
+#         - newVersion: The new library version (e.g., "networkx@1.6")
+#         - jsonPrefix: The prefix path for JSON files (default: ".")
+#         - oldMatchDict: The old version match dictionary (optional, may contain docstring/sourceCode)
+#         - newMatchDict: The new version match dictionary (optional, may contain docstring/sourceCode)
+#  @return ansDict The final answer dictionary
+def findDifferHybridCode(oldPara, newPara, context):
+    # 从 context 中提取参数
+    apiCall = context.get('apiCall')
+    print(f"\n[Hybrid] Analyzing API: {apiCall}")
+    oldVersion = context.get('oldVersion')
+    newVersion = context.get('newVersion')
+    jsonPrefix = context.get('jsonPrefix', '.')
+    oldMatchDict = context.get('oldMatchDict')
+    newMatchDict = context.get('newMatchDict')
+
+    # Step 1: 前置规则处理
+    dic, oldPosRemaining, oldKeyRemaining, newPosRemaining, newKeyRemaining, oldPosParaNum = \
+        applyPreprocessing(oldPara, newPara)
+    print(f"[Hybrid] Step 1 Preprocessing Done. Remaining: oldPos={len(oldPosRemaining)}, oldKey={len(oldKeyRemaining)}")
+
+    # Step 2: 如果还有剩余参数，调用 LLM 处理
+    if len(oldPosRemaining) > 0 or len(oldKeyRemaining) > 0:
+        print(f"[Hybrid] Step 2: Triggering LLM analysis...")
+        # 获取 sourceCode
+        oldSourceCode = getSourceCode(oldMatchDict)
+        newSourceCode = getSourceCode(newMatchDict)
+        print(f"[Hybrid] Data extracted: SourceCode found (Old: {bool(oldSourceCode)}, New: {bool(newSourceCode)})")
+
+
+        # 调用 LLM
+        llmResult = callLLM(
+            apiCall, oldVersion, newVersion,
+            oldPosRemaining, oldKeyRemaining,
+            newPosRemaining, newKeyRemaining,
+            oldSourceCode, newSourceCode
+        )
+
+        # 应用 LLM 分析结果
+        dic = applyLLMResult(dic, llmResult, oldPosRemaining, oldKeyRemaining,
+                             newPosRemaining, newKeyRemaining)
+        print(f"[Hybrid] Step 2: LLM results applied. Dictionary updated.")
+
+    # Step 3: 后处理新增和替换
+    dic = applyPostprocessing(dic, newPosRemaining, newKeyRemaining, oldPosParaNum)
+    print(f"[Hybrid] Step 3: Postprocessing Done.")
+
+    # Step 4: 构建最终答案字典
+    ansDict = buildFinalAnswerDict(dic)
+    print(f"[Hybrid] Step 4: Final answer built. Result keys: {list(ansDict.keys())}")
+
+    return ansDict
