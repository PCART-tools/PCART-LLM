+## Apply hard rules preprocessing to match parameters by name and position
+## 应用硬规则预处理，根据名称和位置匹配参数
+#
+#  这部分对应 changeAnalyze.py:311-387 的前置硬规则处理
+#
+#  @param oldPara The old parameter string from current version
+#  @param newPara The new parameter string from target version
+#  @return (dic, oldPos, oldKey, newPos, newKey, oldPosParaNum) Tuple containing matched dictionary and remaining parameters
+def applyPreprocessing(oldPara, newPara):
+    oldPos, oldKey = para2Obj(oldPara)
+    newPos, newKey = para2Obj(newPara)
+    oldPosParaNum = len(oldPos)
+    dic = {}  # 保存每个参数应该做哪些修改操作
+    
+    # 第一轮筛选，先根据名字来找对应关系
+    # 处理位置参数
+    for oldParaObj in copy.deepcopy(oldPos):
+        sameFlag = 0
+        for newParaObj in newPos:
+            if oldParaObj.name == newParaObj.name:
+                up = Update()
+                if oldParaObj.position != newParaObj.position:
+                    up.pos = newParaObj.position
+                ty = isDifferType(oldParaObj.type, newParaObj.type)
+                if ty:
+                    up.type = ty
+                sameFlag = 1
+                oldPos.remove(oldParaObj)
+                newPos.remove(newParaObj)
+                break
+        if sameFlag == 1:
+            dic[(oldParaObj.name, oldParaObj.position)] = up
+    
+    # 处理关键字参数
+    for oldParaObj in copy.deepcopy(oldKey):
+        sameFlag = 0
+        for newParaObj in newKey:
+            if oldParaObj.name == newParaObj.name:
+                up = Update()
+                ty = isDifferType(oldParaObj.type, newParaObj.type)
+                if ty:
+                    up.type = ty
+                sameFlag = 1
+                oldKey.remove(oldParaObj)
+                newKey.remove(newParaObj)
+                break
+        if sameFlag == 1:
+            dic[(oldParaObj.name, oldParaObj.position)] = up
+
+    # 第二轮筛选，根据名字找对应关系，判断是否存在位置参数变到了关键字参数
+    for oldParaObj in copy.deepcopy(oldPos):
+        sameFlag = 0
+        for newParaObj in newKey:
+            if oldParaObj.name == newParaObj.name:
+                up = Update()
+                up.pos2key = oldParaObj.name  # 位置参数变成关键字参数
+                ty = isDifferType(oldParaObj.type, newParaObj.type)
+                if ty:
+                    up.type = ty
+                sameFlag = 1
+                oldPos.remove(oldParaObj)
+                newKey.remove(newParaObj)
+                break
+        if sameFlag == 1:
+            dic[(oldParaObj.name, oldParaObj.position)] = up
+
+    # 再判断是否有关键字参数(起始版本)变到了位置参数(目标版本)
+    for oldParaObj in copy.deepcopy(oldKey):
+        sameFlag = 0
+        for newParaObj in copy.deepcopy(newPos):
+            if oldParaObj.name == newParaObj.name:
+                up = Update()
+                up.key2pos = oldParaObj.name
+                ty = isDifferType(oldParaObj.type, newParaObj.type)
+                if ty:
+                    up.type = ty
+                sameFlag = 1
+                oldKey.remove(oldParaObj)
+                newPos.remove(newParaObj)
+                break
+        if sameFlag == 1:
+            dic[(oldParaObj.name, oldParaObj.position)] = up
+
+    return dic, oldPos, oldKey, newPos, newKey, oldPosParaNum
+
+
+## Convert parameter objects to JSON format for LLM
+## 将参数对象转换为 LLM 所需的 JSON 格式
+#
+#  @param paraList List of Parameter objects
+#  @param isPositional Whether these are positional parameters
+#  @return jsonList List of dictionaries in JSON format
+def convertParamsToJSON(paraList, isPositional=True):
+    jsonList = []
+    for para in paraList:
+        paramDict = {
+            "name": para.name,
+            "position": para.position,
+            "parameter_type": "positional" if isPositional else "keyword",
+            "data_type": para.type if para.type else None
+        }
+        jsonList.append(paramDict)
+    return jsonList
+
+
+## Get source code from match dictionary or JSON file
+## 从匹配字典或 JSON 文件中获取函数体源代码
+#
+#  优先从 matchDict 中获取；若无则从 _dynamicMatch.json 文件中读取
+#
+#  @param matchDict The match dictionary (may contain sourceCode), can be None
+#  @return sourceCode The source code string, empty if not found
+def getSourceCode(matchDict):
+    # 从 matchDict 中获取 sourceCode（由 mapAPI 动态匹配时填入）
+    # 静态匹配时 matchDict 中无 sourceCode，直接返回空字符串
+    if isinstance(matchDict, dict) and 'sourceCode' in matchDict:
+        return matchDict.get('sourceCode', '')
+    return ''
+
+
+def _normalize_llm_result(raw):
+    # 将 LLM 返回的各种不规范格式归一化为标准结果。
+    # 目标格式为 {"changes": [{"param_name": ..., "position": ..., "rename": ...}, ...]}。
+    # MiniMax 等模型经常无视 json_schema 约束，产出各种字段名变体。
+    if isinstance(raw, dict) and "changes" in raw:
+        changes = raw["changes"]
+        if changes and "param_name" in changes[0] and "rename" in changes[0]:
+            return raw
+
+    items = []
+    if isinstance(raw, dict):
+        items = (
+            raw.get("changes")
+            or raw.get("changed_parameters")
+            or raw.get("renamed_parameters")
+            or raw.get("renames")
+            or []
+        )
+    elif isinstance(raw, list):
+        items = raw
+
+    normalized = []
+    for item in items:
+        if not isinstance(item, dict):
+            continue
+
+        old_name = (
+            item.get("param_name")
+            or item.get("old_name")
+            or item.get("old_parameter")
+        )
+        if isinstance(old_name, dict):
+            old_name = old_name.get("name")
+
+        new_name = (
+            item.get("rename")
+            or item.get("new_name")
+            or item.get("new_parameter")
+        )
+        if isinstance(new_name, dict):
+            new_name = new_name.get("name")
+
+        position = item.get("position")
+        if position is None:
+            old_param_obj = item.get("old_parameter")
+            if isinstance(old_param_obj, dict):
+                position = old_param_obj.get("position")
+
+        if old_name and new_name and position is not None:
+            normalized.append({
+                "param_name": old_name,
+                "position": position,
+                "rename": new_name,
+            })
+
+    if _llm_debug_enabled():
+        print(f"[FIND_DIFFER_LLM_DEBUG] 归一化结果: {{'changes': {normalized}}}")
+
+    return {"changes": normalized}
+
+
+LLM_SKIP_API_KEYWORDS = [
+    "np.array",
+]
+
+
+def shouldSkipLLM(apiCall):
+    apiCallLower = (apiCall or "").lower()
+    return any(keyword.lower() in apiCallLower for keyword in LLM_SKIP_API_KEYWORDS)
+
