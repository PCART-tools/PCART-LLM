+def _llm_debug_enabled():
+    # 当环境变量 FIND_DIFFER_LLM_DEBUG=1 / true / yes / on 时，开启 LLM 原始响应调试输出。
+    v = os.environ.get("FIND_DIFFER_LLM_DEBUG", "").strip().lower()
+    return v in ("1", "true", "yes", "on")
