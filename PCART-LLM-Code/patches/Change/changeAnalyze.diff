+## Serialize and save repairLst to a JSON file for debugging
+## 将 repairLst 序列化并写入 JSON 文件以供调试
+#
+#  Each repairLst entry is a tuple of (repairDict, targetOvPara).
+#  repairDict keys are (name, position) tuples which are not JSON-serializable;
+#  this helper converts them to strings before writing.
+#
+#  @param repairLst The list of (repairDict, targetOvPara) tuples returned by isCompatible
+#  @param context   A dict with keys: callAPI, currentVersion, targetVersion,
+#                   fileRelativePath, lineNum
+#  @param listLabel Either 'tempLst1' (matched path) or 'tempLst2' (unmatched path)
+def _saveRepairLst(repairLst, context, listLabel):
+    if context is None:
+        return
+    try:
+        configPath = context.get('config', '')
+        if configPath:
+            subDir = os.path.dirname(configPath)
+            logDir = os.path.join('Log', 'findDiffer', subDir)
+        else:
+            logDir = os.path.join('Log', 'findDiffer')
+        os.makedirs(logDir, exist_ok=True)
 
+        # Build a file-name-safe string from context fields
+        callAPI   = context.get('callAPI', 'unknown')
+        lineNum   = context.get('lineNum', '0')
+        currVer   = context.get('currentVersion', 'curr')
+        targVer   = context.get('targetVersion', 'targ')
+
+        # Sanitise for file system: keep only alphanumeric / dot / hyphen / underscore
+        def _safe(s):
+            return re.sub(r'[^\w.\-]', '_', str(s))
+
+        fileName = f"{_safe(callAPI)}@{_safe(currVer)}-{_safe(targVer)}_L{_safe(lineNum)}_{listLabel}.json"
+        filePath = os.path.join(logDir, fileName)
+
+        # Serialise: convert tuple keys to strings
+        serialisable = []
+        for repairDict, targetOvPara in repairLst:
+            strKeyDict = {}
+            for k, v in repairDict.items():
+                strKey = f"({k[0]}, {k[1]})"
+                strKeyDict[strKey] = v
+            serialisable.append({
+                'repairDict': strKeyDict,
+                'targetOvPara': targetOvPara
+            })
+
+        payload = {
+            'context': context,
+            'listLabel': listLabel,
+            'repairLst': serialisable
+        }
+
+        with open(filePath, 'w', encoding='utf-8') as fw:
+            json.dump(payload, fw, indent=4, ensure_ascii=False)
+    except Exception as e:
+        print(f"[isCompatible] Warning: failed to save repairLst log: {e}")
+
+
+
